# Copier ce fichier en .env à la racine du projet et remplir les valeurs
# Token d'accès personnel Airtable (Personal Access Token)
# Générer sur : https://airtable.com/create/tokens
AIRTABLE_ACCESS_TOKEN=votre_token_pat_ici

# ID de la base Airtable cible
# Visible dans l'URL : https://airtable.com/appXXXXXXXXXXXXXX/...
AIRTABLE_BASE_ID=votre_base_id_ici

GEMINI_API_KEY=votre_cle_gemini_ici
GROQ_API_KEY=votre_cle_groq_ici
CLOUDINARY_URL=votre_url_cloudinary_ici
